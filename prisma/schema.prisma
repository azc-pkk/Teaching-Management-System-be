generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

/**
 * =========================
 * 枚举类型
 * =========================
 */

enum UserRole {
  ADMIN
  ACADEMIC
  TEACHER
  STUDENT
  LEADER
}

enum UserStatus {
  ENABLED
  DISABLED
}

enum ClassroomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ExamType {
  FINAL
  MAKEUP
  RETAKE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
}

enum GraduationStatus {
  PENDING
  PASSED
  FAILED
}

/**
 * =========================
 * 用户
 * =========================
 */

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique @db.VarChar(50)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  realName     String     @map("real_name") @db.VarChar(50)
  role         UserRole
  status       UserStatus @default(ENABLED)
  phone        String?    @db.VarChar(20)
  email        String?    @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher               Teacher?
  student               Student?
  classroomApplications ClassroomApplication[]

  @@map("sys_user")
}

/**
 * =========================
 * 教研室
 * =========================
 */

model TeachingOffice {
  id           Int     @id @default(autoincrement())
  officeCode   String  @unique @map("office_code") @db.VarChar(30)
  officeName   String  @map("office_name") @db.VarChar(100)
  directorName String? @map("director_name") @db.VarChar(50)
  department   String? @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teachers Teacher[]
  courses  Course[]

  @@map("teaching_office")
}

/**
 * =========================
 * 教师
 * =========================
 */

model Teacher {
  id          Int     @id @default(autoincrement())
  teacherNo   String  @unique @map("teacher_no") @db.VarChar(30)
  teacherName String  @map("teacher_name") @db.VarChar(50)
  teacherType String? @map("teacher_type") @db.VarChar(30)
  title       String? @db.VarChar(50)
  phone       String? @db.VarChar(20)
  email       String? @db.VarChar(100)

  officeId Int? @map("office_id")
  userId   Int? @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  office TeachingOffice? @relation(fields: [officeId], references: [id])
  user   User?           @relation(fields: [userId], references: [id])

  coursesLed       Course[]           @relation("CourseLeader")
  schedules        TeachingSchedule[]
  adjustmentForms  CourseAdjustment[]
  teachingLogs     TeachingLog[]
  invigilatedExams Exam[]             @relation("ExamInvigilator")

  @@map("teacher")
}

/**
 * =========================
 * 专业
 * =========================
 */

model Major {
  id             Int     @id @default(autoincrement())
  majorCode      String  @unique @map("major_code") @db.VarChar(30)
  majorName      String  @map("major_name") @db.VarChar(100)
  departmentName String? @map("department_name") @db.VarChar(100)
  degreeType     String? @map("degree_type") @db.VarChar(30)
  durationYears  Int?    @map("duration_years")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes StudentClass[]

  @@map("major")
}

/**
 * =========================
 * 班级
 * =========================
 */

model StudentClass {
  id            Int     @id @default(autoincrement())
  classCode     String  @unique @map("class_code") @db.VarChar(30)
  className     String  @map("class_name") @db.VarChar(100)
  gradeYear     Int     @map("grade_year")
  campus        String? @db.VarChar(100)
  counselorName String? @map("counselor_name") @db.VarChar(50)
  studentCount  Int     @default(0) @map("student_count")

  majorId Int @map("major_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  major     Major              @relation(fields: [majorId], references: [id])
  students  Student[]
  schedules TeachingSchedule[]
  exams     Exam[]

  @@map("student_class")
}

/**
 * =========================
 * 学生
 * =========================
 */

model Student {
  id            Int     @id @default(autoincrement())
  studentNo     String  @unique @map("student_no") @db.VarChar(30)
  studentName   String  @map("student_name") @db.VarChar(50)
  gender        String? @db.VarChar(10)
  phone         String? @db.VarChar(20)
  email         String? @db.VarChar(100)
  admissionYear Int?    @map("admission_year")
  status        String  @default("ENROLLED") @db.VarChar(30)

  classId Int  @map("class_id")
  userId  Int? @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  studentClass    StudentClass       @relation(fields: [classId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])
  examRecords     ExamStudent[]
  attendance      AttendanceRecord[]
  graduationAudit GraduationAudit?

  @@map("student")
}

/**
 * =========================
 * 课程
 * =========================
 */

model Course {
  id                Int     @id @default(autoincrement())
  courseCode        String  @unique @map("course_code") @db.VarChar(30)
  courseName        String  @map("course_name") @db.VarChar(100)
  credit            Decimal @db.Decimal(4, 1)
  totalHours        Int?    @map("total_hours")
  courseType        String? @map("course_type") @db.VarChar(30)
  assessmentMethod  String? @map("assessment_method") @db.VarChar(50)
  participateMakeup Boolean @default(true) @map("participate_makeup")

  officeId        Int? @map("office_id")
  leaderTeacherId Int? @map("leader_teacher_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  office        TeachingOffice? @relation(fields: [officeId], references: [id])
  leaderTeacher Teacher?        @relation("CourseLeader", fields: [leaderTeacherId], references: [id])

  schedules      TeachingSchedule[]
  exams          Exam[]
  textbookOrders TextbookOrder[]

  @@map("course")
}

/**
 * =========================
 * 教室
 * =========================
 */

model Classroom {
  id          Int             @id @default(autoincrement())
  roomCode    String          @unique @map("room_code") @db.VarChar(30)
  roomName    String          @map("room_name") @db.VarChar(100)
  campus      String?         @db.VarChar(100)
  building    String?         @db.VarChar(100)
  roomType    String?         @map("room_type") @db.VarChar(30)
  capacity    Int
  area        Decimal?        @db.Decimal(8, 2)
  managerName String?         @map("manager_name") @db.VarChar(50)
  status      ClassroomStatus @default(AVAILABLE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedules       TeachingSchedule[]
  applications    ClassroomApplication[]
  adjustedCourses CourseAdjustment[]
  exams           Exam[]

  @@map("classroom")
}

/**
 * =========================
 * 教学安排
 * =========================
 */

model TeachingSchedule {
  id           Int    @id @default(autoincrement())
  semester     String @db.VarChar(30)
  weekInfo     String @map("week_info") @db.VarChar(100)
  weekday      Int
  startSection Int    @map("start_section")
  endSection   Int    @map("end_section")

  courseId    Int @map("course_id")
  teacherId   Int @map("teacher_id")
  classId     Int @map("class_id")
  classroomId Int @map("classroom_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course    Course       @relation(fields: [courseId], references: [id])
  teacher   Teacher      @relation(fields: [teacherId], references: [id])
  classInfo StudentClass @relation(fields: [classId], references: [id])
  classroom Classroom    @relation(fields: [classroomId], references: [id])

  adjustmentForms CourseAdjustment[]
  teachingLogs    TeachingLog[]

  @@index([semester])
  @@index([teacherId, weekday])
  @@index([classroomId, weekday])
  @@map("teaching_schedule")
}

/**
 * =========================
 * 教室申请
 * =========================
 */

model ClassroomApplication {
  id        Int            @id @default(autoincrement())
  purpose   String         @db.VarChar(255)
  useDate   DateTime       @map("use_date") @db.Date
  startTime DateTime       @map("start_time") @db.Time(0)
  endTime   DateTime       @map("end_time") @db.Time(0)
  status    ApprovalStatus @default(PENDING)
  comment   String?        @db.VarChar(255)

  applicantId Int @map("applicant_id")
  classroomId Int @map("classroom_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applicant User      @relation(fields: [applicantId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])

  @@index([classroomId, useDate])
  @@map("classroom_application")
}

/**
 * =========================
 * 调课申请
 * =========================
 */

model CourseAdjustment {
  id             Int            @id @default(autoincrement())
  originalDate   DateTime       @map("original_date") @db.Date
  newDate        DateTime       @map("new_date") @db.Date
  adjustedHours  Int            @default(0) @map("adjusted_hours")
  reason         String         @db.VarChar(500)
  status         ApprovalStatus @default(PENDING)
  departmentNote String?        @map("department_note") @db.VarChar(255)
  academicNote   String?        @map("academic_note") @db.VarChar(255)
  leaderNote     String?        @map("leader_note") @db.VarChar(255)

  scheduleId     Int  @map("schedule_id")
  teacherId      Int  @map("teacher_id")
  newClassroomId Int? @map("new_classroom_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedule     TeachingSchedule @relation(fields: [scheduleId], references: [id])
  teacher      Teacher          @relation(fields: [teacherId], references: [id])
  newClassroom Classroom?       @relation(fields: [newClassroomId], references: [id])

  @@map("course_adjustment")
}

/**
 * =========================
 * 考试
 * =========================
 */

model Exam {
  id            Int      @id @default(autoincrement())
  examCode      String   @unique @map("exam_code") @db.VarChar(30)
  examType      ExamType @map("exam_type")
  examDate      DateTime @map("exam_date") @db.Date
  startTime     DateTime @map("start_time") @db.Time(0)
  endTime       DateTime @map("end_time") @db.Time(0)
  expectedCount Int      @default(0) @map("expected_count")
  actualCount   Int      @default(0) @map("actual_count")
  absentCount   Int      @default(0) @map("absent_count")

  courseId      Int  @map("course_id")
  classId       Int  @map("class_id")
  classroomId   Int  @map("classroom_id")
  invigilatorId Int? @map("invigilator_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course      Course       @relation(fields: [courseId], references: [id])
  classInfo   StudentClass @relation(fields: [classId], references: [id])
  classroom   Classroom    @relation(fields: [classroomId], references: [id])
  invigilator Teacher?     @relation("ExamInvigilator", fields: [invigilatorId], references: [id])

  students ExamStudent[]

  @@index([examDate])
  @@map("exam")
}

/**
 * =========================
 * 考生与成绩
 * =========================
 */

model ExamStudent {
  id            Int      @id @default(autoincrement())
  seatNumber    String?  @map("seat_number") @db.VarChar(20)
  score         Decimal? @db.Decimal(5, 2)
  isAbsent      Boolean  @default(false) @map("is_absent")
  admissionCode String?  @map("admission_code") @db.VarChar(50)

  examId    Int @map("exam_id")
  studentId Int @map("student_id")

  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@map("exam_student")
}

/**
 * =========================
 * 教材
 * =========================
 */

model Textbook {
  id          Int      @id @default(autoincrement())
  isbn        String   @unique @db.VarChar(30)
  bookName    String   @map("book_name") @db.VarChar(150)
  author      String?  @db.VarChar(100)
  publisher   String?  @db.VarChar(100)
  price       Decimal? @db.Decimal(10, 2)
  stock       Int      @default(0)
  description String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders TextbookOrder[]

  @@map("textbook")
}

/**
 * =========================
 * 教材征订
 * =========================
 */

model TextbookOrder {
  id       Int            @id @default(autoincrement())
  semester String         @db.VarChar(30)
  quantity Int
  status   ApprovalStatus @default(PENDING)

  textbookId Int @map("textbook_id")
  courseId   Int @map("course_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  textbook Textbook @relation(fields: [textbookId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])

  @@unique([semester, textbookId, courseId])
  @@map("textbook_order")
}

/**
 * =========================
 * 教学日志
 * =========================
 */

model TeachingLog {
  id              Int       @id @default(autoincrement())
  teachingDate    DateTime  @map("teaching_date") @db.Date
  teachingContent String    @map("teaching_content") @db.Text
  attendanceNote  String?   @map("attendance_note") @db.Text
  submittedAt     DateTime? @map("submitted_at")

  scheduleId Int @map("schedule_id")
  teacherId  Int @map("teacher_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  schedule TeachingSchedule @relation(fields: [scheduleId], references: [id])
  teacher  Teacher          @relation(fields: [teacherId], references: [id])

  attendance AttendanceRecord[]

  @@map("teaching_log")
}

/**
 * =========================
 * 学生考勤
 * =========================
 */

model AttendanceRecord {
  id     Int              @id @default(autoincrement())
  status AttendanceStatus
  remark String?          @db.VarChar(255)

  teachingLogId Int @map("teaching_log_id")
  studentId     Int @map("student_id")

  teachingLog TeachingLog @relation(fields: [teachingLogId], references: [id])
  student     Student     @relation(fields: [studentId], references: [id])

  @@unique([teachingLogId, studentId])
  @@map("attendance_record")
}

/**
 * =========================
 * 毕业资格审核
 * =========================
 */

model GraduationAudit {
  id              Int              @id @default(autoincrement())
  requiredCredits Decimal          @map("required_credits") @db.Decimal(6, 1)
  earnedCredits   Decimal          @map("earned_credits") @db.Decimal(6, 1)
  failedCourses   Int              @default(0) @map("failed_courses")
  status          GraduationStatus @default(PENDING)
  auditComment    String?          @map("audit_comment") @db.VarChar(500)
  auditedAt       DateTime?        @map("audited_at")

  studentId Int @unique @map("student_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@map("graduation_audit")
}
