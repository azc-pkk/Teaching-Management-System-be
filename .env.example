# Copy this file to .env and replace the placeholders with local values.
# URL-encode special characters in the password used by DATABASE_URL.
DATABASE_URL="mysql://root:YOUR_URL_ENCODED_PASSWORD@localhost:3306/teaching_management"

# Local API port reserved for the future Node.js service.
PORT=3000

# Password shared by the eight local seed accounts only.
SEED_DEFAULT_PASSWORD="TmsSeed#2026!"
